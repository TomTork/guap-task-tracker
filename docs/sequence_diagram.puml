@startuml
skinparam sequenceDirection left to right
title Task Tracker - Delegate Task Sequence Diagram

actor Client
participant "Task Service" as TS
participant "User Service" as US
database "Task Database" as TD
database "User Database" as UD

Client -> TS: POST /tasks/{taskId}/delegate?assigneeId=X
activate TS

TS -> TD: Get task by ID
activate TD
TD --> TS: Task data / Not found
deactivate TD

alt Task exists
    TS -> US: GET /users/{assigneeId}
    activate US
    
    US -> UD: Get user by ID
    activate UD
    UD --> US: User data / Not found
    deactivate UD
    
    alt User found
        US --> TS: HTTP 200 OK
        deactivate US
        
        TS -> TD: Update assigneeId
        activate TD
        TD --> TS: Updated
        deactivate TD
        
        TS --> Client: HTTP 200 OK
    else User not found
        US --> TS: HTTP 404 Not Found
        deactivate US
        TS --> Client: HTTP 404 Not Found
    else User Service unavailable
        US --> TS: HTTP 503 / Timeout
        deactivate US
        TS --> Client: HTTP 503 Service Unavailable
    end
else Task doesn't exist
    TS --> Client: HTTP 404 Not Found
end

deactivate TS

@enduml
